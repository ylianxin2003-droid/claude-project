# Streamlit Cloud Secrets template
# ---------------------------------
# Do NOT commit a real secrets.toml to GitHub.
# In Streamlit Cloud: App → Settings → Secrets → paste the content below.

SERENE_API_BASE_URL = "https://spaceweather.bham.ac.uk"
SERENE_API_TOKEN = "your-api-token-here"
SERENE_API_TIMEOUT = "30"
SERENE_AUTH_SCHEME = "Token"

# Optional: nest under [serene] instead
# [serene]
# SERENE_API_BASE_URL = "https://spaceweather.bham.ac.uk"
# SERENE_API_TOKEN = "your-api-token-here"
